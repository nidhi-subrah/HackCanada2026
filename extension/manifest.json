{
  "manifest_version": 3,
  "name": "LinkedIn Networkify",
  "version": "1.0.0",
  "description": "Collects 2nd-degree connections for Networkify",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/mynetwork/*", "https://www.linkedin.com/in/*"],
      "js": ["src/content/collector.js"],
      "run_at": "document_idle"
    }
  ],
  "background": { "service_worker": "src/background/worker.js" },
  "action": { "default_popup": "popup/popup.html" }
}
