# Neo4j AuraDB — use neo4j+s:// for AuraDB, bolt:// for local Docker
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# AI services (all optional — app falls back gracefully)
GEMINI_API_KEY=
BACKBOARD_API_KEY=
SCRAPFLY_API_KEY=
LOGO_DEV_TOKEN=

# Auth0 — required
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# JWT signing — generate with: openssl rand -hex 32
APP_SECRET_KEY=

# Frontend URL (used in auth redirects)
FRONTEND_URL=https://your-app.vercel.app

# Allowed CORS origins — JSON array string
# For local dev:  '["http://localhost:3000"]'
# For production: '["https://your-app.vercel.app"]'
CORS_ORIGINS=["http://localhost:3000"]
